APP_NAME="Ochumelie Ruchki"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ochumelie.ru

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=ochumelie_prod
DB_USERNAME=ochumelie_prod
DB_PASSWORD=${DB_PASSWORD_PROD}

CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
LOG_CHANNEL=stderr
LOG_LEVEL=error

TRUSTED_PROXIES=*

ALLOWED_TIME_SLOTS=09:00,11:00,13:00,15:00
MAX_CLASSES_PER_DAY=3
MIN_DESCRIPTION_LENGTH=10
MAX_PRICE=100000