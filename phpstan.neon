includes:
    - ./vendor/larastan/larastan/extension.neon

parameters:
    level: 0
    paths:
        - app
    excludePaths:
        - app/Http/Requests/*
        - app/Models/*
    reportStaticMethodSignatures: true
    treatPhpDocTypesAsCertain: true
    ignoreErrors:
        - '#Call to an undefined method#'
        - '#Access to an undefined property#'