APP_NAME="Ochumelie Ruchki [UAT]"
APP_ENV=uat
APP_KEY=
APP_DEBUG=false
APP_URL=https://uat.ochumelie.local

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=ochumelie_uat
DB_USERNAME=ochumelie_uat
DB_PASSWORD=your_secure_password_here

CACHE_DRIVER=redis
SESSION_DRIVER=redis
